{
  "name": "kor-assetforge-mobile",
  "version": "1.0.0",
  "description": "KOR AssetForge - Cross-platform mobile marketplace app",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "build:ios": "cd ios && xcodebuild -workspace KorAssetForgeMobile.xcworkspace -scheme KorAssetForgeMobile -configuration Release",
    "build:android": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/stack": "^6.3.20",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.8.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "axios": "^1.6.5",
    "react-query": "^3.39.3",
    "@stellar/js-sdk": "^11.3.0",
    "ethers": "^6.9.1",
    "react-native-biometrics": "^3.4.0",
    "react-native-push-notification": "^8.1.1",
    "react-native-vector-icons": "^10.0.0",
    "react-native-gesture-handler": "^2.14.0",
    "zustand": "^4.4.5",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.73.0",
    "@types/react": "^18.2.37",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.2.2",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.0",
    "eslint": "^8.52.0",
    "prettier": "^3.1.0"
  },
  "jest": {
    "preset": "react-native",
    "testEnvironment": "node"
  }
}
